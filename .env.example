# =====================================================================
# FILE: .env.example
# DESCRIPTION: Reference environment variables template for AgriCore AI.
#              Copy this file to '.env' and populate with your credentials.
# =====================================================================

# ---------------------------------------------------------------------
# Deprecated Gemini API Config
# ---------------------------------------------------------------------
# Optional legacy placeholder only. AgriCore AI now uses NVIDIA for chat,
# planning, translation, and crop disease vision analysis.
GEMINI_API_KEY=

# ---------------------------------------------------------------------
# NVIDIA API Configuration
# ---------------------------------------------------------------------
# Required. NVIDIA API catalog key to authenticate Nemotron/Llama models, including the crop disease vision model.
# Obtain from NVIDIA Build: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional. The reasoning LLM schema. Defaults to 'nvidia/nemotron-3-nano-30b-a3b'.
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Optional. Base URL endpoint for accessing the NVIDIA API.
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1

# Optional. Max timeout in seconds for API calls to the NVIDIA models. Default is 15.0.
NVIDIA_TIMEOUT=15.0

# ---------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------
# Required. SQLAlchemy database connection string.
# For Local/Development (SQLite):
#   sqlite:///../data/agriagent.db
# For Production (Cloud SQL PostgreSQL via TCP or Cloud SQL Auth Proxy):
#   postgresql+pg8000://dbuser:dbpass@127.0.0.1:5432/dbname
# For Production (Cloud SQL PostgreSQL UNIX socket integration):
#   postgresql+pg8000://dbuser:dbpass@/dbname?unix_sock=/cloudsql/project-id:region:instance-name
DATABASE_URL=sqlite:///../data/agriagent.db

# ---------------------------------------------------------------------
# API Server Configuration
# ---------------------------------------------------------------------
# Optional. Network interface bind target. Set to '0.0.0.0' in production to allow container ingress.
HOST=0.0.0.0

# Optional. Port allocation for incoming backend traffic. Cloud Run sets this dynamically. Default is 8000.
PORT=8000

# Required. Secret key used for signing session files and cookies. Make it a secure random hex.
SECRET_KEY=generate_a_secure_random_hex_for_cookies_and_sessions

# ---------------------------------------------------------------------
# JWT Security Configuration
# ---------------------------------------------------------------------
# Required. Symmetric secret key (HS256) used to sign/validate access tokens. Keep private.
# Generate via CLI: openssl rand -hex 32
JWT_SECRET=secure_access_token_secret_hex_here

# Required. Symmetric secret key (HS256) used to sign/validate refresh tokens. Keep private.
# Generate via CLI: openssl rand -hex 32
JWT_REFRESH_SECRET=secure_refresh_token_secret_hex_here

# Optional. Duration in minutes before access token expires. Default: 15
JWT_ACCESS_EXPIRATION_MINUTES=15

# Optional. Duration in days before refresh token expires. Default: 7
JWT_REFRESH_EXPIRATION_DAYS=7

# ---------------------------------------------------------------------
# Google OAuth 2.0 Credentials
# ---------------------------------------------------------------------
# Required. Client ID generated in Google API Console for Single-Sign-On configuration.
# Obtain from Google Cloud Console -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_oauth_google_client_id.apps.googleusercontent.com

# Required. Client Secret generated alongside your Client ID. Must be kept secure.
GOOGLE_CLIENT_SECRET=your_oauth_google_client_secret

